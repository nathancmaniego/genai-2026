{
  "expo": {
    "name": "C.H.U.D",
    "slug": "chud-hud",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "chud",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chud.hud",
      "infoPlist": {
        "NSCameraUsageDescription": "C.H.U.D needs camera access for the heads-up display.",
        "NSMicrophoneUsageDescription": "C.H.U.D needs microphone access for voice commands."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.chud.hud",
      "permissions": ["CAMERA", "RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-screen-orientation",
      [
        "expo-av",
        {
          "microphonePermission": "Allow C.H.U.D to access your microphone."
        }
      ]
    ]
  }
}
